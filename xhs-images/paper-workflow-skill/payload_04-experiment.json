{"html": "<!DOCTYPE html>\n<html>\n<head>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap\" rel=\"stylesheet\"/>\n<style>\n  body { font-family: 'Noto Sans SC', sans-serif; margin: 0; padding: 0; background: #FBFBFA; color: #37352F; }\n  .card { background: #FFFFFF; border: 1px solid #E8E7E3; border-radius: 12px; padding: 32px; margin-bottom: 20px; }\n  .tip-row { display: flex; align-items: flex-start; gap: 16px; padding: 16px 0; border-bottom: 1px solid #F1F1EF; }\n  .tip-row:last-child { border-bottom: none; }\n  .tip-icon { width: 44px; height: 44px; border-radius: 8px; background: #F1F1EF; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }\n  .code-block { background: #F7F6F3; border-radius: 8px; padding: 16px 20px; font-family: 'Courier New', monospace; font-size: 17px; margin-top: 12px; color: #37352F; border-left: 3px solid #E8E7E3; }\n  .tag { display: inline-block; padding: 4px 12px; border-radius: 4px; font-size: 14px; font-weight: 500; }\n</style>\n</head>\n<body style=\"width:1080px;height:1440px;\">\n<div style=\"padding:64px 64px 48px 64px; height:100%; display:flex; flex-direction:column;\">\n\n  <!-- Header -->\n  <div style=\"margin-bottom:36px;\">\n    <div style=\"font-size:14px;color:#9B9A97;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;\">EXPERIMENT TIPS</div>\n    <h2 style=\"font-size:42px;font-weight:900;margin:0 0 12px 0;\">\u5b9e\u9a8c\u5b9e\u73b0\u8981\u70b9</h2>\n    <div style=\"width:60px;height:3px;background:#37352F;border-radius:2px;\"></div>\n  </div>\n\n  <!-- Card 1: Interface Contract -->\n  <div class=\"card\">\n    <div style=\"font-size:26px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:10px;\">\n      <span>\ud83d\udccb</span> \u5148\u5b9a\u4e49\u63a5\u53e3\uff0c\u518d\u5199\u4ee3\u7801\n    </div>\n    <p style=\"font-size:20px;color:#9B9A97;margin:0 0 12px 0;line-height:1.5;\">\u6a21\u5757\u63a5\u53e3\u4e0d\u5339\u914d\u662f #1 bug \u6765\u6e90\u3002\u5148\u5199\u7b7e\u540d\u518d\u5199\u5b9e\u73b0\uff1a</p>\n    <div class=\"code-block\">\n      <span style=\"color:#9B9A97;\"># Module 1: returns (bool, float)</span><br/>\n      def judge_retrieval(q, t=0.7) -> tuple: ...<br/><br/>\n      <span style=\"color:#9B9A97;\"># Module 2: returns dict</span><br/>\n      def retrieve(q, docs, kg) -> dict: ...<br/><br/>\n      <span style=\"color:#9B9A97;\"># Module 3: returns (list, list)</span><br/>\n      def filter_trust(q, docs) -> tuple: ...\n    </div>\n  </div>\n\n  <!-- Card 2: Testing Strategy -->\n  <div class=\"card\">\n    <div style=\"font-size:26px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:10px;\">\n      <span>\ud83e\uddea</span> \u5c0f\u89c4\u6a21\u6d4b\u8bd5 \u2192 \u786e\u8ba4 \u2192 \u5168\u91cf\u8dd1\n    </div>\n    <div class=\"tip-row\">\n      <div class=\"tip-icon\">1\ufe0f\u20e3</div>\n      <div>\n        <div style=\"font-size:20px;font-weight:600;\">10 \u6761\u6d4b\u8bd5\u9a8c\u8bc1\u6d41\u7a0b</div>\n        <div style=\"font-size:17px;color:#9B9A97;\">\u786e\u8ba4 pipeline \u65e0\u62a5\u9519\u3001\u7ed3\u679c\u683c\u5f0f\u6b63\u786e</div>\n      </div>\n    </div>\n    <div class=\"tip-row\">\n      <div class=\"tip-icon\">2\ufe0f\u20e3</div>\n      <div>\n        <div style=\"font-size:20px;font-weight:600;\">\u7528\u6237\u786e\u8ba4\u540e\u5168\u91cf\u8dd1</div>\n        <div style=\"font-size:17px;color:#9B9A97;\">\u5148\u62a5\u544a API \u8d39\u7528\u4f30\u7b97\uff0c\u7b49\u7528\u6237\u786e\u8ba4</div>\n      </div>\n    </div>\n    <div class=\"tip-row\">\n      <div class=\"tip-icon\">3\ufe0f\u20e3</div>\n      <div>\n        <div style=\"font-size:20px;font-weight:600;\">\u7ed3\u679c JSON \u81ea\u52a8\u586b\u5165\u8868\u683c</div>\n        <div style=\"font-size:17px;color:#9B9A97;\">matplotlib \u51fa\u56fe \u2192 \u590d\u5236\u5230 paper/figures/</div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Card 3: Tech Stack -->\n  <div class=\"card\">\n    <div style=\"font-size:26px;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:10px;\">\n      <span>\ud83d\udee0\ufe0f</span> \u5b9e\u9a8c\u6280\u672f\u6808\n    </div>\n    <div style=\"display:flex;flex-wrap:wrap;gap:12px;\">\n      <span class=\"tag\" style=\"background:#EEFBF0;color:#1D7A41;\">uv \u5305\u7ba1\u7406</span>\n      <span class=\"tag\" style=\"background:#E8F0FE;color:#1A56DB;\">DeepSeek API</span>\n      <span class=\"tag\" style=\"background:#FFF8E1;color:#92610E;\">BM25 \u68c0\u7d22</span>\n      <span class=\"tag\" style=\"background:#F3E8FF;color:#6B21A8;\">Knowledge Graph</span>\n      <span class=\"tag\" style=\"background:#FEE2E2;color:#B91C1C;\">matplotlib \u53ef\u89c6\u5316</span>\n      <span class=\"tag\" style=\"background:#F1F5F9;color:#475569;\">HotpotQA \u6570\u636e\u96c6</span>\n    </div>\n  </div>\n\n  <!-- Footer -->\n  <div style=\"margin-top:auto;border-top:1px solid #E8E7E3;padding-top:20px;display:flex;justify-content:space-between;\">\n    <span style=\"color:#9B9A97;font-size:18px;\">4/6</span>\n    <span style=\"color:#2383E2;font-size:18px;\">\u5de6\u6ed1\u7ee7\u7eed \u2192</span>\n  </div>\n</div>\n</body>\n</html>\n", "width": 1080, "height": 1440, "deviceScaleFactor": 2, "delay": 2000}