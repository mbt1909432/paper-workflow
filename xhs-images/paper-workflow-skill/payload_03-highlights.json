{"html": "<!DOCTYPE html>\n<html>\n<head>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap\" rel=\"stylesheet\"/>\n<style>\n  body { font-family: 'Noto Sans SC', sans-serif; margin: 0; padding: 0; background: #FBFBFA; color: #37352F; }\n  .card {\n    background: #FFFFFF; border: 1px solid #E8E7E3; border-radius: 12px;\n    padding: 36px 32px; margin-bottom: 24px;\n  }\n  .card-title { font-size: 26px; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 12px; }\n  .card-item { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 14px; font-size: 20px; line-height: 1.5; }\n  .bullet { width: 8px; height: 8px; border-radius: 50%; background: #2383E2; flex-shrink: 0; margin-top: 10px; }\n  .highlight-box { background: #F1F1EF; border-radius: 8px; padding: 16px 20px; margin-top: 12px; }\n</style>\n</head>\n<body style=\"width:1080px;height:1440px;\">\n<div style=\"padding:64px 64px 48px 64px; height:100%; display:flex; flex-direction:column;\">\n\n  <!-- Header -->\n  <div style=\"margin-bottom:40px;\">\n    <div style=\"font-size:14px;color:#9B9A97;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;\">CORE HIGHLIGHTS</div>\n    <h2 style=\"font-size:42px;font-weight:900;margin:0 0 12px 0;\">\u4e24\u5927\u6838\u5fc3\u4eae\u70b9</h2>\n    <div style=\"width:60px;height:3px;background:#37352F;border-radius:2px;\"></div>\n  </div>\n\n  <!-- Card 1: Parallel -->\n  <div class=\"card\">\n    <div class=\"card-title\">\n      <span style=\"font-size:32px;\">\u26a1</span>\n      \u5e76\u884c\u52a0\u901f\uff1aN \u7bc7\u8bba\u6587 = N \u4e2a Agent \u540c\u65f6\u5904\u7406\n    </div>\n    <div class=\"card-item\">\n      <div class=\"bullet\"></div>\n      <span>PDF \u8f6c MD\uff1a\u6bcf\u7bc7\u8bba\u6587\u5206\u914d\u72ec\u7acb subagent\uff0c\u5e76\u884c\u8f6c\u6362</span>\n    </div>\n    <div class=\"card-item\">\n      <div class=\"bullet\"></div>\n      <span>\u4fe1\u606f\u63d0\u53d6\uff1a10 \u7bc7\u8bba\u6587\u540c\u65f6\u63d0\u53d6 6 \u7ef4\u5ea6\u4fe1\u606f</span>\n    </div>\n    <div class=\"card-item\">\n      <div class=\"bullet\"></div>\n      <span>\u65b9\u6cd5\u878d\u5408\uff1a5 \u4e2a\u89d2\u5ea6 5 \u4e2a subagent \u72ec\u7acb\u5206\u6790</span>\n    </div>\n    <div class=\"highlight-box\">\n      <div style=\"font-size:18px;color:#9B9A97;margin-bottom:8px;\">\u6548\u7387\u5bf9\u6bd4</div>\n      <div style=\"display:flex;gap:32px;\">\n        <div>\n          <div style=\"font-size:36px;font-weight:900;color:#E74C3C;\">\u4e32\u884c</div>\n          <div style=\"font-size:20px;color:#9B9A97;\">~2\u5c0f\u65f6\u5904\u740610\u7bc7</div>\n        </div>\n        <div style=\"font-size:36px;color:#D3D1CB;\">\u2192</div>\n        <div>\n          <div style=\"font-size:36px;font-weight:900;color:#2383E2;\">\u5e76\u884c</div>\n          <div style=\"font-size:20px;color:#9B9A97;\">~15\u5206\u949f\u5904\u740610\u7bc7</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Card 2: Citation Verification -->\n  <div class=\"card\">\n    <div class=\"card-title\">\n      <span style=\"font-size:32px;\">\ud83d\udd12</span>\n      \u4e09\u5c42\u5f15\u7528\u9a8c\u8bc1\uff1a\u62d2\u7edd\u7f16\u9020\uff0c\u6bcf\u6761\u53ef\u8ffd\u6eaf\n    </div>\n    <div style=\"display:flex;flex-direction:column;gap:16px;\">\n      <div style=\"display:flex;align-items:center;gap:16px;padding:16px 20px;background:#F7F6F3;border-radius:8px;\">\n        <div style=\"width:48px;height:48px;border-radius:8px;background:#E8E7E3;display:flex;align-items:center;justify-content:center;font-size:24px;\">1</div>\n        <div>\n          <div style=\"font-size:22px;font-weight:600;\">\u8bba\u6587\u5f15\u7528\u6c60</div>\n          <div style=\"font-size:17px;color:#9B9A97;\">\u4ece10\u7bc7\u8bba\u6587\u7684 References \u4e2d\u63d0\u53d6 ~2000\u6761\u5f15\u7528</div>\n        </div>\n      </div>\n      <div style=\"display:flex;align-items:center;gap:16px;padding:16px 20px;background:#F7F6F3;border-radius:8px;\">\n        <div style=\"width:48px;height:48px;border-radius:8px;background:#E8E7E3;display:flex;align-items:center;justify-content:center;font-size:24px;\">2</div>\n        <div>\n          <div style=\"font-size:22px;font-weight:600;\">\u81ea\u8eab\u5143\u4fe1\u606f</div>\n          <div style=\"font-size:17px;color:#9B9A97;\">\u5339\u914d\u662f\u5426\u4e3a\u6211\u4eec\u6536\u96c6\u768410\u7bc7\u8bba\u6587\u4e4b\u4e00</div>\n        </div>\n      </div>\n      <div style=\"display:flex;align-items:center;gap:16px;padding:16px 20px;background:#F7F6F3;border-radius:8px;\">\n        <div style=\"width:48px;height:48px;border-radius:8px;background:#E8E7E3;display:flex;align-items:center;justify-content:center;font-size:24px;\">3</div>\n        <div>\n          <div style=\"font-size:22px;font-weight:600;\">WebSearch \u5916\u90e8\u9a8c\u8bc1</div>\n          <div style=\"font-size:17px;color:#9B9A97;\">ACL Anthology / Semantic Scholar / Google Scholar</div>\n        </div>\n      </div>\n    </div>\n    <div class=\"highlight-box\" style=\"background:#EEFBF0;\">\n      <span style=\"font-size:18px;\">\u2705 25\u6761\u5f15\u7528\u5168\u90e8\u6709\u660e\u786e\u6765\u6e90\uff0c0\u7f16\u9020</span>\n    </div>\n  </div>\n\n  <!-- Footer -->\n  <div style=\"margin-top:auto;border-top:1px solid #E8E7E3;padding-top:20px;display:flex;justify-content:space-between;\">\n    <span style=\"color:#9B9A97;font-size:18px;\">3/6</span>\n    <span style=\"color:#2383E2;font-size:18px;\">\u5de6\u6ed1\u7ee7\u7eed \u2192</span>\n  </div>\n</div>\n</body>\n</html>\n", "width": 1080, "height": 1440, "deviceScaleFactor": 2, "delay": 2000}