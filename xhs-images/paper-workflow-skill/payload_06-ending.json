{"html": "<!DOCTYPE html>\n<html>\n<head>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap\" rel=\"stylesheet\"/>\n<style>\n  body { font-family: 'Noto Sans SC', sans-serif; margin: 0; padding: 0; background: #FBFBFA; color: #37352F; }\n  .tech-item {\n    display: flex; align-items: center; gap: 14px;\n    padding: 18px 24px; background: #FFFFFF; border: 1px solid #E8E7E3;\n    border-radius: 10px; margin-bottom: 10px;\n  }\n  .tech-logo {\n    width: 44px; height: 44px; border-radius: 8px; background: #F1F1EF;\n    display: flex; align-items: center; justify-content: center; font-size: 22px;\n  }\n  .use-case {\n    padding: 20px 24px; background: #F7F6F3; border-radius: 10px;\n    display: flex; align-items: center; gap: 14px; margin-bottom: 10px;\n  }\n</style>\n</head>\n<body style=\"width:1080px;height:1440px;\">\n<div style=\"padding:64px 64px 48px 64px; height:100%; display:flex; flex-direction:column;\">\n\n  <!-- Header -->\n  <div style=\"margin-bottom:36px;\">\n    <div style=\"font-size:14px;color:#9B9A97;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;\">TECH STACK & USE CASES</div>\n    <h2 style=\"font-size:42px;font-weight:900;margin:0 0 12px 0;\">\u6280\u672f\u6808 & \u9002\u7528\u573a\u666f</h2>\n    <div style=\"width:60px;height:3px;background:#37352F;border-radius:2px;\"></div>\n  </div>\n\n  <!-- Tech Stack -->\n  <div style=\"margin-bottom:36px;\">\n    <div style=\"font-size:22px;font-weight:700;margin-bottom:16px;\">\ud83d\udee0\ufe0f \u6280\u672f\u6808</div>\n    <div class=\"tech-item\">\n      <div class=\"tech-logo\">\ud83e\udd16</div>\n      <div><div style=\"font-size:20px;font-weight:600;\">Claude Code (Opus 4.6)</div><div style=\"font-size:16px;color:#9B9A97;\">AI \u7f16\u7801\u52a9\u624b\uff0c\u9a71\u52a8\u6574\u4e2a\u5de5\u4f5c\u6d41</div></div>\n    </div>\n    <div class=\"tech-item\">\n      <div class=\"tech-logo\">\ud83d\udce6</div>\n      <div><div style=\"font-size:20px;font-weight:600;\">uv</div><div style=\"font-size:16px;color:#9B9A97;\">Python \u5305\u7ba1\u7406\uff0c\u66ff\u4ee3 pip + venv</div></div>\n    </div>\n    <div class=\"tech-item\">\n      <div class=\"tech-logo\">\ud83d\udcdd</div>\n      <div><div style=\"font-size:20px;font-weight:600;\">Tectonic</div><div style=\"font-size:16px;color:#9B9A97;\">\u8f7b\u91cf LaTeX \u7f16\u8bd1\u5668\uff0c\u65e0\u9700 MiKTeX</div></div>\n    </div>\n    <div class=\"tech-item\">\n      <div class=\"tech-logo\">\ud83d\udcc4</div>\n      <div><div style=\"font-size:20px;font-weight:600;\">pymupdf4llm</div><div style=\"font-size:16px;color:#9B9A97;\">\u5b66\u672f\u8bba\u6587 PDF \u2192 Markdown \u8f6c\u6362</div></div>\n    </div>\n    <div class=\"tech-item\">\n      <div class=\"tech-logo\">\ud83e\udde0</div>\n      <div><div style=\"font-size:20px;font-weight:600;\">DeepSeek API</div><div style=\"font-size:16px;color:#9B9A97;\">\u4f4e\u6210\u672c LLM \u8c03\u7528\uff0c\u5b9e\u9a8c\u7528</div></div>\n    </div>\n  </div>\n\n  <!-- Use Cases -->\n  <div style=\"margin-bottom:36px;\">\n    <div style=\"font-size:22px;font-weight:700;margin-bottom:16px;\">\ud83d\udca1 \u9002\u7528\u573a\u666f</div>\n    <div class=\"use-case\">\n      <span style=\"font-size:28px;\">\ud83c\udf93</span>\n      <span style=\"font-size:20px;\">\u7814\u7a76\u751f\u8bfe\u7a0b\u8bba\u6587 / \u6bd5\u4e1a\u8bba\u6587</span>\n    </div>\n    <div class=\"use-case\">\n      <span style=\"font-size:28px;\">\ud83d\udd2c</span>\n      <span style=\"font-size:20px;\">\u7814\u7a76\u8005\u5feb\u901f\u9a8c\u8bc1\u65b0\u65b9\u6cd5</span>\n    </div>\n    <div class=\"use-case\">\n      <span style=\"font-size:28px;\">\ud83d\udcda</span>\n      <span style=\"font-size:20px;\">\u6587\u732e\u7efc\u8ff0\u5199\u4f5c</span>\n    </div>\n    <div class=\"use-case\">\n      <span style=\"font-size:28px;\">\ud83d\udcf0</span>\n      <span style=\"font-size:20px;\">\u4f1a\u8bae / \u671f\u520a\u6295\u7a3f</span>\n    </div>\n  </div>\n\n  <!-- CTA -->\n  <div style=\"margin-top:auto;text-align:center;padding:40px 0;border-top:1px solid #E8E7E3;\">\n    <div style=\"font-size:32px;font-weight:900;margin-bottom:16px;\">\u6536\u85cf = \u5b66\u4f1a \ud83d\udd16<br/>\u70b9\u8d5e = \u652f\u6301 \u2764\ufe0f</div>\n    <div style=\"font-size:20px;color:#9B9A97;margin-bottom:20px;\">\u8bc4\u8bba\u533a\u544a\u8bc9\u6211\u4f60\u60f3\u7528\u6765\u5199\u4ec0\u4e48\u8bba\u6587</div>\n    <div style=\"display:inline-block;background:#37352F;color:#FBFBFA;padding:14px 36px;border-radius:8px;font-size:20px;font-weight:600;\">\n      github.com/mbt1909432/paper-workflow\n    </div>\n  </div>\n\n  <!-- Footer -->\n  <div style=\"border-top:1px solid #E8E7E3;padding-top:20px;text-align:center;\">\n    <span style=\"color:#9B9A97;font-size:18px;\">6/6 \u00b7 \u5168\u90e8\u5b8c</span>\n  </div>\n</div>\n</body>\n</html>\n", "width": 1080, "height": 1440, "deviceScaleFactor": 2, "delay": 2000}