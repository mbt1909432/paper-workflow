{"html": "<!DOCTYPE html>\n<html>\n<head>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap\" rel=\"stylesheet\"/>\n<style>\n  body { font-family: 'Noto Sans SC', sans-serif; margin: 0; padding: 0; background: #FBFBFA; color: #37352F; }\n  .step-row {\n    display: flex; align-items: flex-start; gap: 20px;\n    padding: 20px 24px; margin-bottom: 8px;\n    background: #FFFFFF; border: 1px solid #E8E7E3; border-radius: 8px;\n  }\n  .step-num {\n    width: 40px; height: 40px; border-radius: 50%; background: #F1F1EF;\n    display: flex; align-items: center; justify-content: center;\n    font-size: 18px; font-weight: 700; color: #37352F; flex-shrink: 0;\n  }\n  .step-title { font-size: 22px; font-weight: 700; margin-bottom: 4px; }\n  .step-desc { font-size: 18px; color: #9B9A97; line-height: 1.4; }\n  .step-tool { font-size: 15px; color: #2383E2; margin-top: 4px; }\n  .arrow-down { text-align: center; color: #D3D1CB; font-size: 24px; margin: 4px 0; }\n</style>\n</head>\n<body style=\"width:1080px;height:1440px;\">\n<div style=\"padding:64px 64px 48px 64px; height:100%; display:flex; flex-direction:column;\">\n\n  <!-- Header -->\n  <div style=\"margin-bottom:40px;\">\n    <div style=\"font-size:14px;color:#9B9A97;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;\">WORKFLOW OVERVIEW</div>\n    <h2 style=\"font-size:42px;font-weight:900;margin:0 0 12px 0;\">7 \u6b65\u5b8c\u6574\u5de5\u4f5c\u6d41</h2>\n    <div style=\"width:60px;height:3px;background:#37352F;border-radius:2px;\"></div>\n  </div>\n\n  <!-- Steps -->\n  <div class=\"step-row\">\n    <div class=\"step-num\">1</div>\n    <div>\n      <div class=\"step-title\">\ud83d\udcda \u6587\u732e\u6536\u96c6</div>\n      <div class=\"step-desc\">\u8f93\u5165\u5173\u952e\u8bcd \u2192 arxiv \u641c\u7d22 \u2192 \u7b5b\u9009 \u2192 \u7528\u6237\u786e\u8ba4 \u2192 \u6279\u91cf\u4e0b\u8f7d</div>\n      <div class=\"step-tool\">arxiv API \u00b7 \u5e76\u884c\u4e0b\u8f7d</div>\n    </div>\n  </div>\n  <div class=\"arrow-down\">\u2193</div>\n\n  <div class=\"step-row\">\n    <div class=\"step-num\">2</div>\n    <div>\n      <div class=\"step-title\">\ud83d\udcc4 PDF \u8f6c Markdown</div>\n      <div class=\"step-desc\">\u6279\u91cf\u8f6c\u6362 + \u81ea\u52a8\u6dfb\u52a0\u5143\u4fe1\u606f + \u6e05\u6d17\u683c\u5f0f</div>\n      <div class=\"step-tool\">pymupdf4llm \u00b7 N\u7bc7 = N\u4e2a subagent</div>\n    </div>\n  </div>\n  <div class=\"arrow-down\">\u2193</div>\n\n  <div class=\"step-row\">\n    <div class=\"step-num\">3</div>\n    <div>\n      <div class=\"step-title\">\ud83d\udd0d \u7ed3\u6784\u5316\u4fe1\u606f\u63d0\u53d6</div>\n      <div class=\"step-desc\">6\u7ef4\u5ea6\u63d0\u53d6\uff1aAbstract / Method / Contribution / Limitation / Evaluation / Insights</div>\n      <div class=\"step-tool\">\u5e76\u884c\u5904\u7406 \u00b7 \u4e3a\u878d\u5408\u505a\u51c6\u5907</div>\n    </div>\n  </div>\n  <div class=\"arrow-down\">\u2193</div>\n\n  <div class=\"step-row\">\n    <div class=\"step-num\">4</div>\n    <div>\n      <div class=\"step-title\">\ud83e\udde9 \u591a\u89d2\u5ea6\u65b9\u6cd5\u878d\u5408</div>\n      <div class=\"step-desc\">5\u4e2a\u89d2\u5ea6\u6a2a\u5411\u5bf9\u6bd4 \u2192 Gap \u5206\u6790 \u2192 \u878d\u5408\u65b9\u6848 \u2192 \u9009\u6700\u4f73</div>\n      <div class=\"step-tool\">5\u4e2a subagent \u5e76\u884c\u5206\u6790</div>\n    </div>\n  </div>\n  <div class=\"arrow-down\">\u2193</div>\n\n  <div class=\"step-row\">\n    <div class=\"step-num\">5</div>\n    <div>\n      <div class=\"step-title\">\u270d\ufe0f LaTeX \u8bba\u6587\u64b0\u5199</div>\n      <div class=\"step-desc\">\u81ea\u52a8\u751f\u6210\u5b8c\u6574\u8bba\u6587 + \u4e09\u5c42\u5f15\u7528\u9a8c\u8bc1\uff08\u62d2\u7edd\u7f16\u9020\uff09</div>\n      <div class=\"step-tool\">Tectonic \u7f16\u8bd1 \u00b7 references.bib \u9a8c\u8bc1</div>\n    </div>\n  </div>\n  <div class=\"arrow-down\">\u2193</div>\n\n  <div class=\"step-row\">\n    <div class=\"step-num\">6</div>\n    <div>\n      <div class=\"step-title\">\ud83e\uddea \u5b9e\u9a8c\u5b9e\u73b0\u4e0e\u8fd0\u884c</div>\n      <div class=\"step-desc\">\u5148\u5b9a\u4e49\u63a5\u53e3\u5951\u7ea6 \u2192 \u5199\u4ee3\u7801 \u2192 10\u6761\u6d4b\u8bd5 \u2192 \u786e\u8ba4\u518d\u5168\u91cf\u8dd1</div>\n      <div class=\"step-tool\">uv \u00b7 DeepSeek API \u00b7 matplotlib</div>\n    </div>\n  </div>\n  <div class=\"arrow-down\">\u2193</div>\n\n  <div class=\"step-row\">\n    <div class=\"step-num\">7</div>\n    <div>\n      <div class=\"step-title\">\u2728 \u8bba\u6587\u6da6\u8272</div>\n      <div class=\"step-desc\">\u8bed\u6cd5 / \u903b\u8f91 / \u5b9e\u9a8c / \u53bbAI\u75d5\u8ff9 / Abstract \u8bca\u65ad</div>\n      <div class=\"step-tool\">latex-paper-en skill \u00b7 6\u6a21\u5757\u81ea\u52a8\u5206\u6790</div>\n    </div>\n  </div>\n\n  <!-- Footer -->\n  <div style=\"margin-top:auto;border-top:1px solid #E8E7E3;padding-top:20px;display:flex;justify-content:space-between;\">\n    <span style=\"color:#9B9A97;font-size:18px;\">2/6</span>\n    <span style=\"color:#2383E2;font-size:18px;\">\u5de6\u6ed1\u7ee7\u7eed \u2192</span>\n  </div>\n</div>\n</body>\n</html>\n", "width": 1080, "height": 1440, "deviceScaleFactor": 2, "delay": 2000}