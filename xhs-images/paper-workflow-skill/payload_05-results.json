{"html": "<!DOCTYPE html>\n<html>\n<head>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap\" rel=\"stylesheet\"/>\n<style>\n  body { font-family: 'Noto Sans SC', sans-serif; margin: 0; padding: 0; background: #FBFBFA; color: #37352F; }\n  .result-card {\n    background: #FFFFFF; border: 1px solid #E8E7E3; border-radius: 12px;\n    padding: 24px 28px; margin-bottom: 16px;\n    display: flex; align-items: center; gap: 20px;\n  }\n  .result-num { font-size: 40px; font-weight: 900; color: #2383E2; min-width: 60px; text-align: center; }\n  .result-label { font-size: 20px; font-weight: 500; }\n  .result-detail { font-size: 17px; color: #9B9A97; }\n  .big-stat { text-align: center; padding: 32px; background: #F7F6F3; border-radius: 12px; }\n  .big-num { font-size: 56px; font-weight: 900; color: #37352F; }\n</style>\n</head>\n<body style=\"width:1080px;height:1440px;\">\n<div style=\"padding:64px 64px 48px 64px; height:100%; display:flex; flex-direction:column;\">\n\n  <!-- Header -->\n  <div style=\"margin-bottom:36px;\">\n    <div style=\"font-size:14px;color:#9B9A97;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;\">RESULTS</div>\n    <h2 style=\"font-size:42px;font-weight:900;margin:0 0 12px 0;\">\u5b9e\u9645\u4ea7\u51fa\u6210\u679c</h2>\n    <div style=\"width:60px;height:3px;background:#37352F;border-radius:2px;\"></div>\n  </div>\n\n  <!-- Big stats -->\n  <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:28px;\">\n    <div class=\"big-stat\">\n      <div class=\"big-num\">10</div>\n      <div style=\"font-size:20px;color:#9B9A97;margin-top:4px;\">\u7bc7\u6587\u732e\u8c03\u7814</div>\n    </div>\n    <div class=\"big-stat\">\n      <div class=\"big-num\">5</div>\n      <div style=\"font-size:20px;color:#9B9A97;margin-top:4px;\">\u89d2\u5ea6\u878d\u5408\u5206\u6790</div>\n    </div>\n  </div>\n\n  <!-- Result items -->\n  <div class=\"result-card\">\n    <div class=\"result-num\">1</div>\n    <div>\n      <div class=\"result-label\">\u63d0\u51fa\u521b\u65b0\u65b9\u6cd5\uff1aTA-GraphRAG</div>\n      <div class=\"result-detail\">Trust-Aware Adaptive Graph RAG\uff0c\u878d\u5408 GraphRAG + \u53ef\u4fe1\u6027\u6846\u67b6 + \u81ea\u9002\u5e94\u68c0\u7d22</div>\n    </div>\n  </div>\n\n  <div class=\"result-card\">\n    <div class=\"result-num\">6</div>\n    <div>\n      <div class=\"result-label\">\u6a21\u5757\u5316 Pipeline \u5b9e\u73b0</div>\n      <div class=\"result-detail\">\u68c0\u7d22\u5224\u65ad \u2192 \u56fe\u68c0\u7d22 \u2192 \u53ef\u4fe1\u6027\u8fc7\u6ee4 \u2192 \u56fe\u589e\u5f3a\u751f\u6210 \u2192 \u5e7b\u89c9\u68c0\u6d4b \u2192 \u8fed\u4ee3\u4f18\u5316</div>\n    </div>\n  </div>\n\n  <div class=\"result-card\">\n    <div class=\"result-num\">4</div>\n    <div>\n      <div class=\"result-label\">Baseline \u5bf9\u6bd4\u5b9e\u9a8c</div>\n      <div class=\"result-detail\">Naive RAG / Self-RAG / CRAG / GraphRAG \u56db\u4e2a\u57fa\u7ebf\u65b9\u6cd5</div>\n    </div>\n  </div>\n\n  <div class=\"result-card\">\n    <div class=\"result-num\">25</div>\n    <div>\n      <div class=\"result-label\">\u5f15\u7528\u5168\u90e8\u5916\u90e8\u9a8c\u8bc1</div>\n      <div class=\"result-detail\">\u4e09\u5c42\u9a8c\u8bc1\u673a\u5236\uff0c\u6bcf\u6761\u5f15\u7528\u53ef\u8ffd\u6eaf\u5230\u5916\u90e8\u6765\u6e90\uff0c0 \u7f16\u9020</div>\n    </div>\n  </div>\n\n  <div class=\"result-card\">\n    <div class=\"result-num\">3</div>\n    <div>\n      <div class=\"result-label\">\u53ef\u89c6\u5316\u56fe\u8868\u63d2\u5165\u8bba\u6587</div>\n      <div class=\"result-detail\">\u67f1\u72b6\u56fe + \u96f7\u8fbe\u56fe + \u70ed\u529b\u56fe\uff0cmatplotlib \u751f\u6210</div>\n    </div>\n  </div>\n\n  <!-- GitHub box -->\n  <div style=\"margin-top:auto;background:#FFFFFF;border:1px solid #E8E7E3;border-radius:12px;padding:24px 28px;display:flex;align-items:center;gap:16px;\">\n    <div style=\"width:48px;height:48px;border-radius:8px;background:#F1F1EF;display:flex;align-items:center;justify-content:center;font-size:24px;\">\ud83d\udcc2</div>\n    <div>\n      <div style=\"font-size:20px;font-weight:600;\">\u5168\u90e8\u4ee3\u7801\u5f00\u6e90</div>\n      <div style=\"font-size:17px;color:#2383E2;\">github.com/mbt1909432/paper-workflow</div>\n    </div>\n  </div>\n\n  <!-- Footer -->\n  <div style=\"margin-top:16px;border-top:1px solid #E8E7E3;padding-top:20px;display:flex;justify-content:space-between;\">\n    <span style=\"color:#9B9A97;font-size:18px;\">5/6</span>\n    <span style=\"color:#2383E2;font-size:18px;\">\u5de6\u6ed1\u6700\u540e\u4e00\u9875 \u2192</span>\n  </div>\n</div>\n</body>\n</html>\n", "width": 1080, "height": 1440, "deviceScaleFactor": 2, "delay": 2000}