{"html": "<!DOCTYPE html>\n<html>\n<head>\n<script src=\"https://cdn.tailwindcss.com\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700;900&display=swap\" rel=\"stylesheet\"/>\n<style>\n  body { font-family: 'Noto Sans SC', sans-serif; margin: 0; padding: 0; }\n  .notion-bg { background: #FBFBFA; }\n  .notion-text { color: #37352F; }\n  .notion-gray { color: #9B9A97; }\n  .notion-blue { color: #2383E2; }\n  .notion-border { border: 1px solid #E8E7E3; }\n  .doodle { opacity: 0.12; position: absolute; }\n  .step-circle {\n    width: 28px; height: 28px; border-radius: 50%;\n    background: #E8E7E3; display: flex; align-items: center;\n    justify-content: center; font-size: 13px; font-weight: 500;\n    color: #37352F; flex-shrink: 0;\n  }\n</style>\n</head>\n<body class=\"notion-bg\" style=\"width:1080px;height:1440px;\">\n<div style=\"padding:72px 64px 64px 64px; height:100%; display:flex; flex-direction:column; justify-content:center; position:relative;\">\n\n  <!-- Decorative doodles -->\n  <svg class=\"doodle\" style=\"top:60px;right:80px;width:120px;height:120px;\" viewBox=\"0 0 120 120\">\n    <circle cx=\"60\" cy=\"60\" r=\"50\" fill=\"none\" stroke=\"#37352F\" stroke-width=\"1.5\" stroke-dasharray=\"4 6\"/>\n  </svg>\n  <svg class=\"doodle\" style=\"bottom:120px;left:60px;width:80px;height:80px;\" viewBox=\"0 0 80 80\">\n    <rect x=\"10\" y=\"10\" width=\"60\" height=\"60\" rx=\"8\" fill=\"none\" stroke=\"#37352F\" stroke-width=\"1.5\" transform=\"rotate(15 40 40)\"/>\n  </svg>\n\n  <!-- Tag -->\n  <div style=\"display:inline-flex;align-items:center;gap:8px;margin-bottom:32px;\">\n    <span style=\"background:#E8E7E3;color:#37352F;padding:6px 16px;border-radius:4px;font-size:18px;font-weight:500;\">\n      \ud83d\udd27 AI\u5de5\u5177\n    </span>\n    <span style=\"background:#E8E7E3;color:#37352F;padding:6px 16px;border-radius:4px;font-size:18px;font-weight:500;\">\n      \ud83d\udcdd \u5b66\u672f\u5199\u4f5c\n    </span>\n  </div>\n\n  <!-- Main Title -->\n  <h1 class=\"notion-text\" style=\"font-size:64px;font-weight:900;line-height:1.2;margin:0 0 24px 0;letter-spacing:-1px;\">\n    \u7528 Claude Code<br/>\u4ece\u96f6\u5199\u8bba\u6587\n  </h1>\n\n  <p class=\"notion-text\" style=\"font-size:28px;font-weight:400;margin:0 0 48px 0;opacity:0.7;line-height:1.5;\">\n    7\u6b65\u5168\u6d41\u7a0b AI \u5de5\u4f5c\u6d41 Skill<br/>\n    <span style=\"font-size:24px;opacity:0.5;\">\u4ece\u6587\u732e\u8c03\u7814\u5230\u5b9e\u9a8c\u8fd0\u884c\uff0c\u4e00\u4e2a Skill \u641e\u5b9a</span>\n  </p>\n\n  <!-- Mini flow preview -->\n  <div style=\"display:flex;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:48px;\">\n    <div style=\"display:flex;align-items:center;gap:6px;\"><div class=\"step-circle\">1</div><span style=\"font-size:16px;color:#9B9A97;\">\u6587\u732e</span></div>\n    <span style=\"color:#D3D1CB;font-size:20px;\">\u2192</span>\n    <div style=\"display:flex;align-items:center;gap:6px;\"><div class=\"step-circle\">2</div><span style=\"font-size:16px;color:#9B9A97;\">\u8f6c\u6362</span></div>\n    <span style=\"color:#D3D1CB;font-size:20px;\">\u2192</span>\n    <div style=\"display:flex;align-items:center;gap:6px;\"><div class=\"step-circle\">3</div><span style=\"font-size:16px;color:#9B9A97;\">\u63d0\u53d6</span></div>\n    <span style=\"color:#D3D1CB;font-size:20px;\">\u2192</span>\n    <div style=\"display:flex;align-items:center;gap:6px;\"><div class=\"step-circle\">4</div><span style=\"font-size:16px;color:#9B9A97;\">\u878d\u5408</span></div>\n    <span style=\"color:#D3D1CB;font-size:20px;\">\u2192</span>\n    <div style=\"display:flex;align-items:center;gap:6px;\"><div class=\"step-circle\">5</div><span style=\"font-size:16px;color:#9B9A97;\">\u64b0\u5199</span></div>\n    <span style=\"color:#D3D1CB;font-size:20px;\">\u2192</span>\n    <div style=\"display:flex;align-items:center;gap:6px;\"><div class=\"step-circle\">6</div><span style=\"font-size:16px;color:#9B9A97;\">\u5b9e\u9a8c</span></div>\n    <span style=\"color:#D3D1CB;font-size:20px;\">\u2192</span>\n    <div style=\"display:flex;align-items:center;gap:6px;\"><div class=\"step-circle\">7</div><span style=\"font-size:16px;color:#9B9A97;\">\u6da6\u8272</span></div>\n  </div>\n\n  <!-- Bottom line -->\n  <div style=\"border-top:1px solid #E8E7E3;padding-top:24px;display:flex;justify-content:space-between;align-items:center;\">\n    <span class=\"notion-gray\" style=\"font-size:20px;\">\u5168\u6d41\u7a0b\u53ef\u590d\u73b0 \u00b7 \u5f00\u6e90 Skill</span>\n    <span style=\"font-size:20px;color:#2383E2;font-weight:500;\">\u53f3\u6ed1\u67e5\u770b\u8be6\u60c5 \u2192</span>\n  </div>\n</div>\n</body>\n</html>\n", "width": 1080, "height": 1440, "deviceScaleFactor": 2, "delay": 2000}